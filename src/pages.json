{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "subPages",
      "pages": [
        {
          "path": "welcome/index"
        }
      ]
    }
  ],
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-([^-].*)": "@/uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "",
    "navigationBarBackgroundColor": "#F8E6B8",
    "backgroundColor": "#F8E6B8"
  }
}
